# Copy to .env.local and fill in to enable booking + contact email delivery.
# Until RESEND_API_KEY is set, forms still work but log the submission instead
# of emailing (see lib/email.ts).

# Get a key at https://resend.com (free tier).
RESEND_API_KEY=

# Verified sender. For testing you can use Resend's shared onboarding address.
RESEND_FROM="Renoun Creation <onboarding@resend.dev>"

# Where booking + contact submissions are delivered.
BOOKING_TO_EMAIL=imrsteelo@gmail.com
